# ============================================
# AI Personal Assistant — Environment Config
# ============================================
# Only ONE provider key is needed. Priority: Groq > Together > Gemini > OpenAI > HF

# --- Option 1: Groq (RECOMMENDED — fast, free tier) ---
GROQ_API_KEY=gsk_your_groq_key_here

# --- Option 2: Together AI ---
# TOGETHER_API_KEY=your_together_key_here

# --- Option 3: Google Gemini ---
# GEMINI_API_KEY=your_gemini_key_here

# --- Option 4: OpenAI ---
# OPENAI_API_KEY=sk-your_openai_key_here

# --- Option 5: Hugging Face (OSS only, no frontier) ---
# HF_API_TOKEN=hf_your_token_here

# --- Model Overrides (optional — sensible defaults per provider) ---
# OSS_MODEL=llama-3.1-8b-instant
# FRONTIER_MODEL=llama-3.3-70b-versatile

# --- Memory ---
MAX_MEMORY_TURNS=20
SUMMARY_THRESHOLD=15

# --- Safety ---
ENABLE_GUARDRAILS=true

# --- Observability ---
LOG_LEVEL=INFO
